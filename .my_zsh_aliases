# navigation
alias repos="cd ~/repos/"
alias vimconfig="cd ~/dotfiles/.config/nvim"
alias config="cd ~/dotfiles/"

# common unix tools
alias vim=nvim
alias ll="ls -lAh --color=auto"

# tools 
alias k9s="k9s --kubeconfig kubeconfig"
alias lzg="lazygit"
alias lzd="lazydocker"

# git helpers
alias ec="git commit --allow-empty -m \"- Trigger CI\" && git push"

# new task folder
alias newtask="pipx run cookiecutter ~/dev/cookiecutter_templates/task"

# fzf helper
alias cf="cd \$(find ~ * -type d | fzf)"
alias cff="cd \$(find * -type d | fzf)"
